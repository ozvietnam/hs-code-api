# Copy to .env (gitignored). Never commit real keys.
#   cp .env.example .env

HS_API_TOKEN=
HS_ADMIN_TOKEN=

GEMINI_API_KEY=
GEMINI_RERANK_MODEL=gemini-2.5-flash
GEMINI_DESCRIBE_MODEL=gemini-2.5-flash
GEMINI_ENRICH_MODEL=gemini-2.5-flash

# Hermes Pool — cổng AI dùng chung (LiteLLM proxy, chuẩn OpenAI).
# Nhóm key theo dự án; dự án này = key-hs-knowledge. base_url + key thật lấy từ tài liệu bàn giao AXIT.
# KHÔNG điền IP/key thật vào file này (repo public). Ưu tiên #1 cho batch enrich + runtime fallback.
HERMES_BASE_URL=
HERMES_API_KEY=
HERMES_ENRICH_MODEL=reasoning

MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_ENRICH_MODEL=MiniMax-M2.7

OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/api
OLLAMA_ENRICH_MODEL=gemma4:31b

# OpenRouter — free models + fallback (docs/openrouter.md)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=https://your-app.vercel.app
OPENROUTER_APP_NAME=hs-code-api
