{
  "framework": null,
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/", "destination": "/admin/index.html" },
    { "source": "/api/versions", "destination": "/api/tariff-versions" },
    { "source": "/api/versions/", "destination": "/api/tariff-versions" },
    { "source": "/api/version", "destination": "/api/tariff-version" },
    { "source": "/api/version/", "destination": "/api/tariff-version" },
    { "source": "/api/version/diff", "destination": "/api/tariff-version-diff" },
    { "source": "/api/version-diff", "destination": "/api/tariff-version-diff" }
  ],
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
